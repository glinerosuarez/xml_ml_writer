<role-properties xmlns="http://marklogic.com/manage">
  <role-name>protein_loader</role-name>
  <description>protein loader role</description>
  <roles>
    <role>protein_analyst</role>
    <role>reader</role>
  </roles>
  <privileges>
    <privilege>
      <privilege-name>create-trigger</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/create-trigger</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>xdbc:insert-in</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/xdbc-insert-in</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>rest-writer</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/rest-writer</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>xdbc:insert</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/xdbc-insert</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>xdmp:sleep</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/xdmp-sleep</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>xdmp:document-load</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/xdmp-document-load</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>any-uri</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/any-uri</action>
      <kind>execute</kind>
    </privilege>
    <privilege>
      <privilege-name>any-collection</privilege-name>
      <action>http://marklogic.com/xdmp/privileges/any-collection</action>
      <kind>execute</kind>
    </privilege>
  </privileges>
</role-properties>
